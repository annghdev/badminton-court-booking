@using Web.Client.Models
@inherits LayoutComponentBase
@inject NavigationManager _navigation

<Layout>
    <Header Class="header">
            <img class="logo" src="images/logo.png" />
    </Header>
    <Layout>
        <Sider Collapsible Theme="SiderTheme.Light" Width="250">
        <Menu Theme="MenuTheme.Light" DefaultSelectedKeys=@(new[]{"1"}) Mode="MenuMode.Inline">
            <MenuItem Key="2" RouterLink="/court-schedule/1" RouterMatch="NavLinkMatch.All">
                <Icon Type="@IconType.Outline.Calendar" />
                <span>Lịch đặt sân</span>
            </MenuItem>
            <MenuItem Key="3" RouterLink="/users" RouterMatch="NavLinkMatch.All">
                        <Icon Type="@IconType.Outline.User" />
                        <span>Người dùng</span>
            </MenuItem>
            @{
                RenderFragment sub3Title =
                    @<span>
                        <Icon Type="@IconType.Outline.Control" />
                        <span>Thiết lập</span>
                    </span>;
            }
            <SubMenu Key="sub3" TitleTemplate=sub3Title>
                <MenuItem Key="7" RouterLink="/timeslots">
                    <Icon Type="@IconType.Outline.FieldTime" />
                    <span>Khung giờ</span>
                </MenuItem>
                <MenuItem Key="8" RouterLink="/voucher-management">
                    <Icon Type="@IconType.Outline.Barcode" />
                    <span>Phiếu giảm giá</span>
                </MenuItem>
            </SubMenu>
        </Menu>
    </Sider>
        <Layout>
            <Content Class="site-layout-background" Style=" padding: 16px; margin: 0; min-height: 100vh;">
                @Body
            </Content>
        </Layout>
    </Layout>
</Layout>

<style>
    .logo {
        width: 120px;
        height: 48px;
        margin: 4px 32px 0px -48px;
        float: left;
    }

    .site-layout-background {
        background: #fff;
    }
</style>

@code {

    // protected override void OnInitialized()
    // {
    // }


    private void GoToLogin()
    {
        _navigation.NavigateTo("login");
    }
    
}